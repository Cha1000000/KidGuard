<!-- Зачёркнутый глобус («запрет сайтов»). Цвет задаётся tint в Icon(). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Окружность глобуса -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.9"
        android:strokeLineCap="round"
        android:pathData="M3,12 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0" />
    <!-- Экватор -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.9"
        android:strokeLineCap="round"
        android:pathData="M3,12 L21,12" />
    <!-- Меридиан -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.9"
        android:strokeLineCap="round"
        android:pathData="M12,3 a4.5,9 0 1,0 0,18 a4.5,9 0 1,0 0,-18" />
    <!-- Диагональ-зачёркивание (поверх) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.9"
        android:strokeLineCap="round"
        android:pathData="M5.6,5.6 L18.4,18.4" />
</vector>
