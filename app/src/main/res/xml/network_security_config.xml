<?xml version="1.0" encoding="utf-8"?>
<!--
    Cleartext (HTTP без TLS) разрешён ТОЧЕЧНО только для адресов KidGuard-server:
    10.0.2.2 — алиас эмулятора Android на localhost хост-машины (локальный dev-сервер,
    debug-сборка), 157.22.172.217 — боевой AdminVPS (release; пока по IP:порт, шаг 4.7).
    Остальной трафик приложения — по умолчанию (HTTPS-only). После заведения поддомена
    с HTTPS оба domain-config нужно будет убрать.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">157.22.172.217</domain>
    </domain-config>
</network-security-config>
